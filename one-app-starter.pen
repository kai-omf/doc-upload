        },
        {
          "type": "frame",
          "id": "e3M9G",
          "name": "Spec",
          "width": "fill_container",
          "fill": "$color-surface-layer-2",
          "cornerRadius": "$shape-radius-medium-1",
          "layout": "vertical",
          "gap": 8,
          "padding": 24,
          "children": [
            {
              "type": "text",
              "id": "JwX0L",
              "name": "Spec Text",
              "fill": "$color-body-default",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "CHECKBOX — SPEC (design-system handoff)\nRoot: horizontal, height height-component-small-1 = 40px, width hugs content, gap gap-x-component-large. Label is composed externally.\nState Layer + Box: 24×24 fixed, radius shape-radius-small-1. Unselected = transparent box + state stroke. Selected = filled box + white check.\nCheck: 20px unchecked/hidden; 22px selected. Dimensions are literal px because Pencil size properties do not bind variables reliably.\nFocus: State Layer 2px outer line-focus ring. Pressed: 3px outer core-blue-200 ring.\nStates: Enabled · Hover · Pressed · Focus · Disabled · Error.\nArchitecture follows Button, Badge, Alert, Accordion, and Bottom Nav Item: one reusable Checkbox source component plus a sticker sheet of instances with targeted overrides.",
              "lineHeight": 1.5,
              "fontFamily": "$font-family-primary",
              "fontSize": 12,
              "fontWeight": "normal"
            }
          ]
        },
